<nav class="navbar custom-navbar">
  <div class="container px-4">

    <!-- ロゴエリア -->
    <div class="navbar-logo">
      <%= link_to(user_signed_in? ? authenticated_root_path : unauthenticated_root_path,
                  class: "logo-link") do %>
        <%= image_tag "kibun_gohan_logo.png",
              alt: "きぶんご飯",
              class: "logo-img" %>
      <% end %>
    </div>

    <!-- メニューエリア -->
    <div class="navbar-menu">
      <ul class="navbar-nav flex-row align-items-center gap-3">

        <!-- ホームリンク -->
        <li class="nav-item">
          <%= link_to "🏠 ホーム",
                      user_signed_in? ? authenticated_root_path : unauthenticated_root_path,
                      class: "nav-link" %>
        </li>

        <% if user_signed_in? %>
          <li class="nav-item">
            <%= link_to "⭐ お気に入り",
              favorites_path,
              class: "nav-link" %>
          </li>
        <% end %>

        <% if user_signed_in? %>
          <!-- ログイン中ユーザーのドロップダウン -->
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
              👤 <%= current_user.name.present? ? current_user.name : current_user.email %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li>
                <%= link_to "📝 プロフィール編集", edit_user_registration_path, class: "dropdown-item" %>
              </li>
              <li><hr class="dropdown-divider"></li>
              <li>
                <%= link_to "🚪 ログアウト", destroy_user_session_path, 
                            data: { turbo_method: :delete }, 
                            class: "dropdown-item" %>
              </li>
            </ul>
          </li>
        <% else %>
          <!-- 未ログイン時ボタン -->
          <li class="nav-item">
            <%= link_to "🔑 ログイン", new_user_session_path, class: "btn btn-outline-warning btn-sm" %>
          </li>
          <li class="nav-item">
            <%= link_to "✨ 新規登録", new_user_registration_path, class: "btn btn-warning btn-sm" %>
          </li>
        <% end %>

      </ul>
    </div>

  </div>
</nav>
